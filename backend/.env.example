# Gemini Vision API
# Get your key at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK
# Option 1 — local dev: path to a service account JSON file
# Download from Firebase Console > Project Settings > Service Accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Option 2 — Cloud Run deployment: leave GOOGLE_APPLICATION_CREDENTIALS unset
# and grant the Cloud Run service account these IAM roles instead:
#   - Cloud Datastore User        (Firestore read/write)
#   - Storage Object Admin        (Firebase Storage)
#   - Firebase Authentication Admin

# Firebase project ID (used by Admin SDK when not using a service account file)
FIREBASE_PROJECT_ID=your_firebase_project_id

# Server port (optional, defaults to 8080)
# PORT=8080
